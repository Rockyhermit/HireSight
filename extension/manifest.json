{
  "manifest_version": 3,
  "name": "HireSphere Clipper",
  "version": "1.0.1",
  "description": "Save job postings directly to HireSphere",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://www.indeed.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
